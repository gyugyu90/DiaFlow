{
  "name": "diaflow",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite --config apps/demo/vite.config.ts --host 127.0.0.1",
    "build": "tsc -b && vite build --config apps/demo/vite.config.ts",
    "preview": "vite preview --config apps/demo/vite.config.ts --host 127.0.0.1",
    "test": "vitest run --config vitest.config.ts",
    "check": "npm test && npm run build"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^4.1.10"
  }
}
