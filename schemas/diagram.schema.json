{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "https://raw.githubusercontent.com/gyugyu90/DiaFlow/main/schemas/diagram.schema.json",
  "title": "DiaFlow Diagram",
  "description": "Source-of-truth document for a DiaFlow interactive architecture diagram.",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.2",
      "description": "Diagram JSON contract version."
    },
    "id": {
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
      "description": "Unique diagram document identifier."
    },
    "kind": {
      "type": "string",
      "const": "architecture",
      "description": "Diagram vertical supported by this schema version."
    },
    "metadata": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable diagram title."
        },
        "description": {
          "type": "string",
          "description": "Optional diagram summary."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Optional ISO 8601 creation timestamp."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Optional ISO 8601 last-update timestamp."
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional search and classification tags."
        }
      },
      "required": [
        "title"
      ],
      "additionalProperties": false,
      "description": "Human-facing diagram metadata."
    },
    "viewport": {
      "type": "object",
      "properties": {
        "x": {
          "type": "number",
          "description": "Initial horizontal canvas translation."
        },
        "y": {
          "type": "number",
          "description": "Initial vertical canvas translation."
        },
        "zoom": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Initial positive zoom scale."
        }
      },
      "required": [
        "x",
        "y",
        "zoom"
      ],
      "additionalProperties": false,
      "description": "Initial viewer camera state."
    },
    "theme": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "light",
            "dark"
          ],
          "description": "Base light or dark appearance."
        },
        "accent": {
          "type": "string",
          "description": "Accent color preset or CSS color."
        },
        "background": {
          "type": "string",
          "description": "Diagram background color."
        }
      },
      "required": [
        "mode",
        "accent",
        "background"
      ],
      "additionalProperties": false,
      "description": "Document-level visual theme."
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
            "description": "Unique node identifier referenced by edges, groups, and scenes."
          },
          "type": {
            "type": "string",
            "enum": [
              "user",
              "browser",
              "mobile",
              "load_balancer",
              "api",
              "app",
              "server",
              "worker",
              "database",
              "cache",
              "queue",
              "storage",
              "cdn",
              "external_service",
              "network",
              "group",
              "unknown"
            ],
            "description": "Semantic architecture component type."
          },
          "label": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable node label."
          },
          "description": {
            "type": "string",
            "description": "Optional explanation of the node's role."
          },
          "position": {
            "type": "object",
            "properties": {
              "x": {
                "type": "number",
                "description": "Horizontal canvas coordinate in diagram units."
              },
              "y": {
                "type": "number",
                "description": "Vertical canvas coordinate in diagram units."
              }
            },
            "required": [
              "x",
              "y"
            ],
            "additionalProperties": false,
            "description": "Absolute top-left node position on the canvas."
          },
          "size": {
            "type": "object",
            "properties": {
              "width": {
                "type": "number",
                "exclusiveMinimum": 0,
                "description": "Positive width in diagram units."
              },
              "height": {
                "type": "number",
                "exclusiveMinimum": 0,
                "description": "Positive height in diagram units."
              }
            },
            "required": [
              "width",
              "height"
            ],
            "additionalProperties": false,
            "description": "Optional node size; the runtime uses its default size when omitted."
          },
          "icon": {
            "type": "string",
            "description": "Optional icon name understood by the runtime."
          },
          "ports": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
                  "description": "Port identifier unique within this node."
                },
                "side": {
                  "type": "string",
                  "enum": [
                    "top",
                    "right",
                    "bottom",
                    "left"
                  ],
                  "description": "Node side where the port is rendered."
                }
              },
              "required": [
                "id",
                "side"
              ],
              "additionalProperties": false
            },
            "description": "Optional named connection points."
          },
          "data": {
            "type": "object",
            "additionalProperties": {},
            "description": "Extension data ignored by the core schema."
          }
        },
        "required": [
          "id",
          "type",
          "label",
          "position"
        ],
        "additionalProperties": false,
        "description": "A component or participant in the diagram."
      },
      "description": "All nodes in the diagram."
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
            "description": "Unique edge identifier referenced by animations and scenes."
          },
          "source": {
            "type": "object",
            "properties": {
              "nodeId": {
                "type": "string",
                "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
                "description": "Referenced node identifier."
              },
              "portId": {
                "type": "string",
                "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
                "description": "Optional port identifier on the referenced node."
              }
            },
            "required": [
              "nodeId"
            ],
            "additionalProperties": false,
            "description": "Source endpoint."
          },
          "target": {
            "type": "object",
            "properties": {
              "nodeId": {
                "type": "string",
                "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
                "description": "Referenced node identifier."
              },
              "portId": {
                "type": "string",
                "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
                "description": "Optional port identifier on the referenced node."
              }
            },
            "required": [
              "nodeId"
            ],
            "additionalProperties": false,
            "description": "Target endpoint."
          },
          "label": {
            "type": "string",
            "description": "Optional relationship or protocol label."
          },
          "direction": {
            "type": "string",
            "enum": [
              "none",
              "forward",
              "backward",
              "bidirectional"
            ],
            "default": "forward",
            "description": "Semantic edge direction; defaults to forward."
          },
          "style": {
            "type": "object",
            "properties": {
              "line": {
                "type": "string",
                "enum": [
                  "solid",
                  "dashed",
                  "dotted"
                ],
                "default": "solid",
                "description": "Line pattern; defaults to solid."
              },
              "routing": {
                "type": "string",
                "enum": [
                  "straight",
                  "smooth",
                  "orthogonal"
                ],
                "default": "smooth",
                "description": "Path routing mode; defaults to smooth."
              },
              "color": {
                "type": "string",
                "default": "default",
                "description": "Runtime color preset or CSS color; defaults to default."
              },
              "labelPlacement": {
                "type": "string",
                "enum": [
                  "center",
                  "above",
                  "below"
                ],
                "default": "above",
                "description": "Label position relative to the edge; defaults to above."
              },
              "startMarker": {
                "type": "string",
                "enum": [
                  "none",
                  "arrow",
                  "triangle",
                  "circle"
                ],
                "description": "Optional marker at the source endpoint."
              },
              "endMarker": {
                "type": "string",
                "enum": [
                  "none",
                  "arrow",
                  "triangle",
                  "circle"
                ],
                "description": "Optional marker at the target endpoint."
              }
            },
            "additionalProperties": false,
            "description": "Static visual styling with canonical defaults.",
            "default": {}
          },
          "data": {
            "type": "object",
            "additionalProperties": {},
            "description": "Extension data ignored by the core schema."
          }
        },
        "required": [
          "id",
          "source",
          "target"
        ],
        "additionalProperties": false,
        "description": "A connection or communication path between two nodes."
      },
      "description": "All edges in the diagram."
    },
    "groups": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
            "description": "Unique group identifier."
          },
          "label": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable group label."
          },
          "nodeIds": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
              "description": "Stable identifier beginning with a letter and containing only letters, digits, underscores, or hyphens."
            },
            "description": "Unique node identifiers owned by this group; a node can belong to only one group."
          },
          "style": {
            "type": "object",
            "properties": {
              "variant": {
                "type": "string",
                "enum": [
                  "boundary",
                  "lane",
                  "none"
                ],
                "default": "boundary",
                "description": "Group rendering variant; defaults to boundary."
              }
            },
            "additionalProperties": false,
            "default": {},
            "description": "Group styling with canonical defaults."
          }
        },
        "required": [
          "id",
          "label",
          "nodeIds"
        ],
        "additionalProperties": false,
        "description": "A visual grouping that owns its node membership through nodeIds."
      },
      "description": "Optional visual node groups."
    },
    "animations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
            "description": "Unique animation identifier referenced by scenes."
          },
          "type": {
            "type": "string",
            "enum": [
              "packet",
              "request",
              "response",
              "cache_hit",
              "cache_miss",
              "retry",
              "broadcast",
              "step_reveal",
              "none"
            ],
            "description": "Semantic meaning of the animated flow."
          },
          "edgeIds": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
              "description": "Stable identifier beginning with a letter and containing only letters, digits, underscores, or hyphens."
            },
            "minItems": 1,
            "description": "Ordered unique edge identifiers included in this animation."
          },
          "enabled": {
            "type": "boolean",
            "description": "Whether the animation can be rendered."
          },
          "direction": {
            "type": "string",
            "enum": [
              "forward",
              "backward",
              "bidirectional"
            ],
            "default": "forward",
            "description": "Playback direction; defaults to forward."
          },
          "speed": {
            "type": "number",
            "exclusiveMinimum": 0,
            "default": 1,
            "description": "Positive playback speed multiplier; defaults to 1."
          },
          "loop": {
            "type": "boolean",
            "default": true,
            "description": "Whether playback repeats; defaults to true."
          },
          "label": {
            "type": "string",
            "description": "Optional human-readable animation label."
          },
          "payload": {
            "type": "object",
            "additionalProperties": {},
            "description": "Optional semantic payload carried by the flow."
          }
        },
        "required": [
          "id",
          "type",
          "edgeIds",
          "enabled"
        ],
        "additionalProperties": false,
        "description": "A flow animation that owns its edge membership through edgeIds."
      },
      "description": "Optional flow animations."
    },
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
            "description": "Unique scene identifier."
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable scene title."
          },
          "description": {
            "type": "string",
            "description": "Optional explanation of the scenario step."
          },
          "animationIds": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
              "description": "Stable identifier beginning with a letter and containing only letters, digits, underscores, or hyphens."
            },
            "description": "Unique animations active in this scene; all enabled animations are active when omitted."
          },
          "edgeOverrides": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "edgeId": {
                  "type": "string",
                  "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
                  "description": "Edge identifier affected in this scene."
                },
                "label": {
                  "type": "string",
                  "description": "Scene-specific edge label."
                },
                "disabled": {
                  "type": "boolean",
                  "description": "Whether the edge is disabled in this scene."
                },
                "tone": {
                  "type": "string",
                  "enum": [
                    "normal",
                    "active",
                    "warning",
                    "danger",
                    "muted"
                  ],
                  "description": "Scene-specific semantic edge tone."
                },
                "style": {
                  "type": "object",
                  "properties": {
                    "line": {
                      "type": "string",
                      "enum": [
                        "solid",
                        "dashed",
                        "dotted"
                      ],
                      "default": "solid",
                      "description": "Line pattern; defaults to solid."
                    },
                    "routing": {
                      "type": "string",
                      "enum": [
                        "straight",
                        "smooth",
                        "orthogonal"
                      ],
                      "default": "smooth",
                      "description": "Path routing mode; defaults to smooth."
                    },
                    "color": {
                      "type": "string",
                      "default": "default",
                      "description": "Runtime color preset or CSS color; defaults to default."
                    },
                    "labelPlacement": {
                      "type": "string",
                      "enum": [
                        "center",
                        "above",
                        "below"
                      ],
                      "default": "above",
                      "description": "Label position relative to the edge; defaults to above."
                    },
                    "startMarker": {
                      "type": "string",
                      "enum": [
                        "none",
                        "arrow",
                        "triangle",
                        "circle"
                      ],
                      "description": "Optional marker at the source endpoint."
                    },
                    "endMarker": {
                      "type": "string",
                      "enum": [
                        "none",
                        "arrow",
                        "triangle",
                        "circle"
                      ],
                      "description": "Optional marker at the target endpoint."
                    }
                  },
                  "additionalProperties": false,
                  "description": "Scene-specific partial edge style."
                }
              },
              "required": [
                "edgeId"
              ],
              "additionalProperties": false,
              "description": "Scene-specific changes applied to one edge."
            },
            "description": "Scene-specific edge changes with at most one override per edge."
          },
          "nodeOverrides": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "nodeId": {
                  "type": "string",
                  "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
                  "description": "Node identifier affected in this scene."
                },
                "tone": {
                  "type": "string",
                  "enum": [
                    "normal",
                    "active",
                    "warning",
                    "danger",
                    "muted"
                  ],
                  "description": "Scene-specific semantic node tone."
                },
                "status": {
                  "type": "string",
                  "description": "Optional scene-specific node status text."
                }
              },
              "required": [
                "nodeId"
              ],
              "additionalProperties": false,
              "description": "Scene-specific changes applied to one node."
            },
            "description": "Scene-specific node changes with at most one override per node."
          }
        },
        "required": [
          "id",
          "title"
        ],
        "additionalProperties": false,
        "description": "One scenario step over the shared diagram structure."
      },
      "description": "Optional ordered scenario steps."
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "kind",
    "metadata",
    "viewport",
    "theme",
    "nodes",
    "edges"
  ],
  "additionalProperties": false
}
