        "line": "dotted",
        "routing": "smooth",
        "color": "accent",
        "labelPlacement": "below",
        "startMarker": "none",
        "endMarker": "arrow"
      },
      "data": {
        "parameters": [
          "code",
          "state"
        ]
      }
    },
    {
      "id": "edge_client_read_verifier",
      "source": {
        "nodeId": "pkce_state"
      },
      "target": {
        "nodeId": "browser_client"
      },
      "label": "Load code_verifier",
      "direction": "forward",
      "style": {
        "line": "dashed",
        "routing": "smooth",
        "color": "accent",
        "labelPlacement": "above",
        "startMarker": "none",
        "endMarker": "arrow"
      }
    },
    {
      "id": "edge_client_token_request",
      "source": {
        "nodeId": "browser_client"
      },
      "target": {
        "nodeId": "token_endpoint"
      },
      "label": "Token request: code + verifier",
      "direction": "forward",
      "style": {
        "line": "solid",
        "routing": "smooth",
        "color": "accent",
        "labelPlacement": "above",
        "startMarker": "none",
        "endMarker": "arrow"
      },
      "data": {
        "parameters": [
          "grant_type=authorization_code",
          "code",
          "redirect_uri",
          "client_id",
          "code_verifier"
        ]
      }
    },
    {
      "id": "edge_token_verify",
      "source": {
        "nodeId": "token_endpoint"
      },
      "target": {
        "nodeId": "authorization_server"
      },
      "label": "Verify S256",
      "direction": "bidirectional",
      "style": {
        "line": "solid",
        "routing": "smooth",
        "color": "default",
        "labelPlacement": "below",
        "startMarker": "arrow",
        "endMarker": "arrow"
      },
      "data": {
        "check": "BASE64URL-ENCODE(SHA256(code_verifier)) equals stored code_challenge"
      }
    },
    {
      "id": "edge_token_response",
      "source": {
        "nodeId": "token_endpoint"
      },
      "target": {
        "nodeId": "browser_client"
      },
      "label": "Access token",
      "direction": "forward",
      "style": {
        "line": "dotted",
        "routing": "smooth",
        "color": "accent",
        "labelPlacement": "below",
        "startMarker": "none",
        "endMarker": "arrow"
      }
    },
    {
      "id": "edge_api_request",
      "source": {
        "nodeId": "browser_client"
      },
      "target": {
        "nodeId": "resource_api"
      },
      "label": "API request: Bearer token",
      "direction": "forward",
      "style": {
        "line": "solid",
        "routing": "smooth",
        "color": "accent",
        "labelPlacement": "above",
        "startMarker": "none",
        "endMarker": "arrow"
      }
    },
    {
      "id": "edge_api_response",
      "source": {
        "nodeId": "resource_api"
      },
      "target": {
        "nodeId": "browser_client"
      },
