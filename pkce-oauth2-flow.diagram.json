      "style": {
        "line": "solid",
        "routing": "smooth",
        "color": "default",
        "labelPlacement": "above",
        "startMarker": "none",
        "endMarker": "arrow"
      }
    },
    {
      "id": "edge_auth_code_redirect",
      "source": {
        "nodeId": "authorization_server"
      },
      "target": {
        "nodeId": "browser_client"
      },
