      "style": {
        "line": "solid",
        "routing": "smooth",
        "color": "default",
        "labelPlacement": "above",
        "startMarker": "none",
        "endMarker": "arrow"
      }
    },
    {
      "id": "edge_user_login",
      "source": {
        "nodeId": "user"
      },
      "target": {
        "nodeId": "login_consent"
      },
