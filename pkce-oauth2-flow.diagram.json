        "nodeId": "pkce_state"
      },
      "label": "Store code_verifier",
      "direction": "forward",
      "style": {
        "line": "dashed",
        "routing": "smooth",
        "color": "accent",
        "labelPlacement": "below",
        "startMarker": "none",
        "endMarker": "arrow"
      }
    },
    {
