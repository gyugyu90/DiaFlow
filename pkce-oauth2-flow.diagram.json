  "animations": [
    {
      "id": "anim_generate_pkce",
      "type": "step_reveal",
      "edgeIds": [
        "edge_client_store_verifier"
      ],
      "enabled": true,
      "direction": "forward",
      "speed": 0.8,
      "loop": true,
      "label": "Generate PKCE values",
      "payload": {
        "produces": [
          "code_verifier",
          "code_challenge"
        ]
      }
    },
    {
      "id": "anim_authorization_request",
      "type": "request",
      "edgeIds": [
        "edge_user_client",
        "edge_client_auth_request"
      ],
      "enabled": true,
      "direction": "forward",
