      "enabled": true,
      "direction": "forward",
      "speed": 1.1,
      "loop": true,
      "label": "Exchange code for token",
      "payload": {
        "security": "The code is useless without the original code_verifier."
      }
    },
    {
      "id": "anim_token_response",
      "type": "response",
      "edgeIds": [
        "edge_token_response"
      ],
      "enabled": true,
      "direction": "forward",
      "speed": 1,
      "loop": true,
      "label": "Token response"
    },
    {
      "id": "anim_api_call",
      "type": "request",
      "edgeIds": [
        "edge_api_request",
        "edge_api_response"
      ],
      "enabled": true,
